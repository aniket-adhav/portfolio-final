{
  "buildCommand": "node ./scripts/draco.cjs && pnpm run build",
  "installCommand": "pnpm install --ignore-scripts",
  "builds": [
    {
      "src": "vercel-handler.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["build/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/vercel-handler.js" }
  ]
}
